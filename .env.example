# CodeValdOrg — environment configuration example.
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------
# Required — the process refuses to start without these.
# -------------------------------------------------------------------

# The single agency this process serves. Baked into every handler.
# AGENCY_ID=agency-abc123

# ArangoDB cluster endpoints (comma-separated URLs).
# ARANGO_ENDPOINTS=http://localhost:8529

# ArangoDB authentication.
# ARANGO_USER=root
# ARANGO_PASSWORD=

# CodeValdCross gRPC address for the Register heartbeat.
# CROSS_ENDPOINT=:50051

# Public URL of this process (appears in token iss claims and /.well-known doc).
# ORG_ISSUER_URL=https://org.example.com

# -------------------------------------------------------------------
# Optional — sensible defaults apply when unset.
# -------------------------------------------------------------------

# ArangoDB database name. Default: agency-${AGENCY_ID}
# ARANGO_DB_NAME=agency-abc123

# Combined gRPC + HTTP listener address (cmux). Default: :9090
# BIND_ADDR=:9090

# Telemetry/metrics endpoint. Default: :9091
# METRICS_ADDR=:9091

# Access token TTL. Default: 1h
# ORG_ACCESS_TOKEN_TTL=1h

# Refresh token TTL. Default: 720h (30 days)
# ORG_REFRESH_TOKEN_TTL=720h

# Authorization code TTL. Default: 60s
# ORG_AUTH_CODE_TTL=60s

# Grace window after RotateClientSecret during which the old secret still works.
# Default: 5m
# ORG_CLIENT_SECRET_GRACE=5m

# Argon2id parameters (time cost, memory in KiB, parallelism).
# ORG_ARGON2_TIME=3
# ORG_ARGON2_MEMORY_KIB=65536
# ORG_ARGON2_THREADS=4

# Cross heartbeat cadence. Default: 20s
# ORG_REGISTRAR_INTERVAL=20s

# Per-RPC timeout for Cross Register calls. Default: 5s
# CROSS_PING_TIMEOUT=5s

# Log level: debug / info / warn / error. Default: info
# LOG_LEVEL=info
